{
  "manifest_version": 3,
  "name": "BioTrack Santé",
  "version": "1.0",
  "permissions": ["sidePanel", "activeTab", "scripting"],
  "action": {
    "default_title": "Ouvrir BioTrack"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ]
}
